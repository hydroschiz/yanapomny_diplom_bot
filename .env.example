# ============================================
# VK Bot Configuration
# ============================================
# VK community access token and group ID.
VK_ACCESS_TOKEN=your_vk_group_access_token_here
VK_GROUP_ID=123456789

# Bot username (without @), used for group mentions.
BOT_USERNAME=yanapomnyu_bot

# All-in-one mode runs schedulers and webhook inside the bot process.
# Set these to false when using standalone `scheduler` / `webhook` services.
BOT_SCHEDULER_ENABLED=true
BOT_WEBHOOK_ENABLED=true

# Admin user IDs (comma-separated)
ADMINS=123456789,987654321

# ============================================
# MongoDB Configuration
# ============================================
# MongoDB connection string
# Format: mongodb://user:password@host:port/database?authSource=admin
# For docker-compose: mongodb://admin:password@mongodb:27017/tgBot?authSource=admin
# For local development: mongodb://localhost:27017/tgBot
MONGO_URI=mongodb://admin:your_strong_password@mongodb:27017/tgBot?authSource=admin

# MongoDB credentials (used by docker-compose)
MONGO_USER=admin
MONGO_PASS=your_strong_password_here

# ============================================
# Redis Configuration
# ============================================
# Redis URL for caching pending payments
# For docker-compose: redis://redis:6379/
# For local development: redis://127.0.0.1:6379/
REDIS_URL=redis://redis:6379/

# ============================================
# LLM API Configuration
# ============================================
# URL of the LLM API service (Go microservice for parsing reminders)
# For docker-compose: http://llm_api:8080
# For local development: http://localhost:8080
LLM_API_URL=http://llm_api:8080

# OpenRouter API key for LLM service (optional, has default)
# Get your key from https://openrouter.ai/
# Default key is already configured, uncomment to override:
# OPENAI_API_KEY=sk-or-v1-your_api_key_here

# ============================================
# YooKassa Payment Configuration
# ============================================
# Set to `false` for reminder-only launches when payment flows are not needed.
# If omitted, payments are enabled automatically only when both YK credentials are present.
PAYMENTS_ENABLED=false

# YooKassa credentials for payment processing
# Get them from https://yookassa.ru/
YK_SHOP_ID=your_shop_id_here
YK_SECRET_KEY=your_secret_key_here

# Return URL after payment
YK_RETURN_URL=https://vk.com/yanapomnyu

# Receipt settings for Russian fiscalization
YK_VAT_CODE=1
YK_PAYMENT_SUBJECT=service
YK_PAYMENT_MODE=full_payment
YK_TAX_SYSTEM_CODE=1
YK_RECEIPT_EMAIL_SUFFIX=yanapomnyu.ru

# ============================================
# Twitch/YouTube Notifications (optional)
# ============================================
# Twitch API credentials for channel notifications
# Get them from https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_ID=your_twitch_client_id
# TWITCH_ACCESS_TOKEN=your_twitch_access_token

# ============================================
# HTTP Server Configuration
# ============================================
# IP address to bind HTTP server (for YooKassa webhooks)
IP=0.0.0.0

# Port for HTTP server
PORT=3001

# ============================================
# Logging Configuration
# ============================================
# Log level: trace, debug, info, warn, error
RUST_LOG=info
